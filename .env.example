# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-YOUR_ACTUAL_OPENAI_API_KEY_HERE

# xAI Grok TTS — Fast narration with 80+ voices, 28 languages, voice cloning
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Stripe — Credit purchases
# Get keys from: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks (endpoint: /api/buy-credits)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Instructions:
# 1. Copy this file to .env
# 2. Replace YOUR_ACTUAL_OPENAI_API_KEY_HERE with your real OpenAI API key
# 3. Create a Supabase project at https://supabase.com
# 4. Replace the Supabase values with your actual project credentials
# 5. Run the SQL schema in your Supabase SQL editor
# 6. Rebuild the project: npm run build
# 7. Restart the service: pm2 restart webapp
#
# Note: For Cloudflare Workers deployment, set environment variables in the Cloudflare dashboard